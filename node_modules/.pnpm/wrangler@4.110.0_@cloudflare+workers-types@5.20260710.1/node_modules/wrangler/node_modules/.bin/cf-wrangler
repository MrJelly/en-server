if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/mnt/d/my/store/server/node_modules/.pnpm/wrangler@4.110.0_@cloudflare+workers-types@5.20260710.1/node_modules/wrangler/bin/node_modules:/mnt/d/my/store/server/node_modules/.pnpm/wrangler@4.110.0_@cloudflare+workers-types@5.20260710.1/node_modules/wrangler/node_modules:/mnt/d/my/store/server/node_modules/.pnpm/wrangler@4.110.0_@cloudflare+workers-types@5.20260710.1/node_modules:/mnt/d/my/store/server/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/mnt/d/my/store/server/node_modules/.pnpm/wrangler@4.110.0_@cloudflare+workers-types@5.20260710.1/node_modules/wrangler/bin/node_modules:/mnt/d/my/store/server/node_modules/.pnpm/wrangler@4.110.0_@cloudflare+workers-types@5.20260710.1/node_modules/wrangler/node_modules:/mnt/d/my/store/server/node_modules/.pnpm/wrangler@4.110.0_@cloudflare+workers-types@5.20260710.1/node_modules:/mnt/d/my/store/server/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../bin/cf-wrangler.js" "$@"
else
  exec node  "$basedir/../../bin/cf-wrangler.js" "$@"
fi
