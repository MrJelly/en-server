{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "en",
  "main": "src/worker.ts",
  "compatibility_date": "2026-07-10",
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "speaking-library",
      "database_id": "513f4cdd-0948-426e-a193-263a1e99b86d",
      "migrations_dir": "migrations"
    }
  ],
  "r2_buckets": [
    {
      "binding": "MEDIA",
      "bucket_name": "speaking-library-media"
    }
  ],
  "vars": {
    "CORS_ORIGIN": "*"
  }
}